{
  "Server": {
    "Url": "https://audit-server.company.com",
    "AllowedUrls": [],
    "TimeoutSeconds": 60
  },
  "Security": {
    "AesKeyPath": "./keys/aes-key.bin",
    "RsaPrivateKeyPath": "./keys/agent-private.pem",
    "RsaPublicKeyPath": "./keys/agent-public.pem",
    "ClientCertPath": "./certs/agent.pfx",
    "ClientCertPassword": "",
    "ServerCaCertPath": "./certs/server-ca.cer"
  },
  "Schedule": {
    "IntervalMinutes": 1440,
    "RunAtStartup": true
  },
  "Output": {
    "SaveLocalCopy": true,
    "LocalPath": "./reports/",
    "EncryptLocalCopy": true
  },
  "Logging": {
    "FilePath": "./logs/audit-agent.log",
    "MaxFileSizeMb": 10,
    "MaxFiles": 5
  }
}
